# ─── Copy this file to .env for local development ───
# On Render, set these in: Dashboard → your service → Environment
# (render.yaml already lists them for you; this file is just a local reference)

# Flask secret key — any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# ── Supabase connection (from Supabase Dashboard → Project Settings → API) ──
# SUPABASE_URL is the "Project URL", e.g. https://abcxyzproject.supabase.co
# (this is NOT the Postgres connection string — the app talks to Supabase's
#  REST API, not directly to Postgres)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# SUPABASE_KEY must be the "Secret key" (starts with sb_secret_...). On older
# projects this is instead called the "service_role" key, under a "Legacy API
# Keys" tab — either works, the app doesn't care which format it is. Do NOT
# use the "Publishable key" / "anon" key. This app does its own admin/auth
# checks in Python and needs full read/write access to every table. Never
# expose this key to a browser or commit it to source control.
SUPABASE_KEY=YOUR_SECRET_KEY

# Optional: store deposit-proof uploads in Supabase Storage instead of local
# disk (recommended for Render, since its disk is wiped on every deploy).
# Run the storage bucket SQL at the bottom of supabase_setup.sql first.
USE_SUPABASE_STORAGE=false

# You do NOT need to set RENDER — Render sets it to "true" automatically on
# every service it runs. It's only listed here so local runs without it
# behave like local development (HTTP-friendly cookies, local upload folder).

# Optional: show a "down for maintenance" page to everyone except logged-in
# admins (who can still use the dashboard normally to fix things). Toggling
# this on Render takes ~30-60s to apply, same as any other env var change.
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=
